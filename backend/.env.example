# External source page for HTML parsing
ALFAFOREX_PAGE_URL=https://alfaforex.ru/economic-calendar/

# Refresh interval for backend auto-sync (seconds)
ALFAFOREX_SYNC_TTL_SECONDS=300

# Comma-separated list of allowed frontend origins for CORS.
# Example:
# FRONTEND_ORIGINS=https://your-frontend.vercel.app,https://your-domain.com
FRONTEND_ORIGINS=

# Optional CORS origin regex (useful for Vercel preview domains).
# Example:
# FRONTEND_ORIGIN_REGEX=^https://.*\.vercel\.app$
FRONTEND_ORIGIN_REGEX=
